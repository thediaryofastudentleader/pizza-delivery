{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    // 1️⃣ Serve static assets (js, css, media, etc.) directly
    { "src": "/static/(.*)", "dest": "/static/$1" },

    // 2️⃣ Serve other public assets (favicon, manifest, etc.) directly
    { "src": "/(.+)\\.(txt|ico|png|jpg|jpeg|svg|webp|json)$", "dest": "/$1" },

    // 3️⃣ The exact root URL → the built index.html
    { "src": "/$", "dest": "/index.html" },

    // 4️⃣ All other client‑side routes also fall back to index.html
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
